}


6) Print Pascal’s triangle.
-->public class Pattern6 {
    public static void main(String[] args) {
        int n = 5;

        for (int i = 0; i < n; i++) {
            int num = 1;

            for (int j = 0; j <= n; j++) {
                if (j <= i) {
                    System.out.print(num + " ");
                    num = num * (i - j) / (j + 1);
                } else {
                    System.out.print("  ");
                }
            }
            System.out.println();
        }
    }
}


7) Print diamond pattern of *.
-->public class Pattern7 {
    public static void main(String[] args) {
        int n = 5;

        // Upper
        for (int i = 1; i <= n; i++) {
            for (int j = 1; j <= 2 * n - 1; j++) {
                if (j >= n - i + 1 && j <= n + i - 1) {
                    System.out.print("*");
                } else {
                    System.out.print(" ");
                }
            }
            System.out.println();
        }

        // Lower
        for (int i = n - 1; i >= 1; i--) {
            for (int j = 1; j <= 2 * n - 1; j++) {
                if (j >= n - i + 1 && j <= n + i - 1) {
                    System.out.print("*");
                } else {
                    System.out.print(" ");
                }
            }
            System.out.println();
        }
    }
}


8) Print hollow square pattern using *.
-->public class Pattern8 {
    public static void main(String[] args) {
        int n = 5;

        for (int i = 1; i <= n; i++) {
            for (int j = 1; j <= n; j++) {
                if (i == 1 || i == n || j == 1 || j == n) {
                    System.out.print("* ");
                } else {
                    System.out.print("  ");
                }
            }
            System.out.println();
        }
    }
}


