1) Implement a simple thread-safe Singleton class?
class Singleton {

    private static Singleton obj;

    private Singleton() {
    }

    synchronized static Singleton getInstance() {

        if(obj == null) {

            obj = new Singleton();
        }

        return obj;
    }
}

public class Main {

    public static void main(String[] args) {

        Singleton s1 =
                Singleton.getInstance();

        Singleton s2 =
                Singleton.getInstance();

        System.out.println(s1 == s2);
    }
}



2) Producer-Consumer problem using wait/notify?
class Company {

    int item;
    boolean produced = false;

    synchronized void produce(int item)
            throws Exception {

        if(produced) {

            wait();
        }

        this.item = item;

        System.out.println("Produced: " + item);

        produced = true;

        notify();
    }

    synchronized void consume()
            throws Exception {

        if(!produced) {

            wait();
        }

        System.out.println("Consumed: " + item);

        produced = false;

        notify();
    }
}

