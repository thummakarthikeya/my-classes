5. Write a program to calculate the sum of all numbers in a list using lambda.
-->import java.util.*;

public class Demo {
    public static void main(String[] args) {

        List<Integer> list =
        Arrays.asList(10,20,30,40);

        int sum = list.stream()
                      .reduce(0, (a,b) -> a + b);

        System.out.println(sum);
    }
}

