Example Question

If

@ means +
# means –
$ means ×
% means ÷

Find the value of:

8 $ 3 @ 6 # 4
Solution

Replace symbols:

8 × 3 + 6 − 4

Use BODMAS

8 × 3 = 24
24 + 6 = 30
30 − 4 = 26

✅ Answer = 26



// Online Java Compiler
// Use this editor to write, compile and run your Java code online

class Main {
    public static void main(String[] args) {
        
        
        // @ means +
        // # means –
        // $ means ×
        // % means ÷
        
        String str = "8$3@6#4";
        String str2 = "8 $ 3 @ 6 # 4";
        str = str.replace("@","+");
        str = str.replace("#","-");
        str = str.replace("$","*");
        str = str.replace("%","/");
       
       int num = str.charAt(0) - '0' ;
       
       
        for(int i=1; i<str.length(); i+=2){
            int next = str.charAt(i+1) - '0' ;
            char op = str.charAt(i);
            if(op == '+'){
                // System.out.println("+");
                num = num+next;
            }else if(op == '-'){
                num = num-next;
                // System.out.println("+");
            }else if(op == '*'){
                num = num*next;
                // System.out.println("+");
            }else if(op == '/'){
                num = num/next;
                // System.out.println("+");
            }
            
        }
        
        System.out.println(num);
       
        
    }
}



